<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body{font-family:Arial,sans-serif;color:#333;font-size:14px;}
    .header{background:#628db6;color:white;padding:16px 20px;}
    .header h2{margin:0;font-size:18px;}
    .content{padding:20px;background:#f9f9f9;}
    table{width:100%;border-collapse:collapse;background:white;}
    th{background:#628db6;color:white;padding:10px 12px;text-align:left;font-size:13px;}
    td{padding:10px 12px;border-bottom:1px solid #e0e0e0;font-size:13px;vertical-align:top;}
    tr:nth-child(even) td{background:#f2f6fb;}
    .badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;background:#e8f0fe;color:#1a56db;font-weight:bold;}
    .no-update{color:#999;font-style:italic;}
    .footer{padding:14px 20px;font-size:12px;color:#888;background:#f0f0f0;border-top:1px solid #ddd;}
    a{color:#628db6;text-decoration:none;}
  </style>
</head>
<body>
  <div class="header"><h2>📋 Recordatorio de Tickets Asignados</h2></div>
  <div class="content">
    <p>Hola <strong><%= @user.name %></strong>,<br>
    Tienes <strong><%= @issues.size %> ticket(s)</strong> asignado(s) pendiente(s):</p>
    <table>
      <thead>
        <tr>
          <th>#</th><th>Proyecto</th><th>Asunto</th><th>Estado</th><th>Creado</th><th>Última actualización</th>
        </tr>
      </thead>
      <tbody>
        <% @issues.each do |issue| %>
          <% last_j = issue.journals.where.not(notes:[nil,'']).order(created_on: :desc).first %>
          <% url = "#{Setting.protocol}://#{Setting.host_name}/issues/#{issue.id}" %>
          <tr>
            <td><a href="<%= url %>">#<%= issue.id %></a></td>
            <td><%= issue.project.name %></td>
            <td><a href="<%= url %>"><%= issue.subject %></a></td>
            <td><span class="badge"><%= issue.status.name %></span></td>
            <td><%= issue.created_on.strftime('%d/%m/%Y %H:%M') %></td>
            <td><%= last_j ? last_j.created_on.strftime('%d/%m/%Y %H:%M') : '<span class="no-update">Sin actualizaciones</span>'.html_safe %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="footer">
    Enviado por <strong><%= Setting.app_title %></strong> —
    <a href="<%= Setting.protocol %>://<%= Setting.host_name %>"><%= Setting.host_name %></a>
  </div>
</body>
</html>
