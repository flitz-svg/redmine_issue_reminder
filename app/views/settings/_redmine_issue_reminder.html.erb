<div id="ir-plugin-settings">
<style>
  /* Anular el float de Redmine en labels reales */
  #ir-plugin-settings label {
    float: none !important; width: auto !important;
    text-align: left !important;
  }
  /* Descripciones — usamos div, no label, para no interferir con CSS de Redmine */
  #ir-plugin-settings .ir-label {
    display: block; font-weight: bold; font-size: 13px; color: #444;
    margin: 10px 0 3px 0; clear: both;
  }
  #ir-plugin-settings .ir-label small {
    font-weight: normal; color: #888; font-size: 11px;
  }
  #ir-plugin-settings select { min-width: 220px; display: block; margin-top: 2px; }
  #ir-plugin-settings input[type=number] { width: 60px; }

  /* Toggle */
  .ir-toggle-row { display: flex; align-items: center; gap: 10px; margin: 4px 0 10px; }
  .ir-tgl-wrap {
    position: relative; display: inline-block;
    width: 44px; height: 24px; flex-shrink: 0;
    cursor: pointer;
  }
  .ir-tgl-wrap input { opacity: 0; width: 0; height: 0; position: absolute; }
  .ir-tgl-slider {
    position: absolute; inset: 0;
    background: #ccc; border-radius: 24px; transition: .3s;
  }
  .ir-tgl-slider::before {
    content: ""; position: absolute;
    width: 18px; height: 18px; left: 3px; bottom: 3px;
    background: #fff; border-radius: 50%; transition: .3s;
  }
  .ir-tgl-wrap input:checked + .ir-tgl-slider             { background: #628db6; }
  .ir-tgl-wrap input:checked + .ir-tgl-slider::before     { transform: translateX(20px); }
  .ir-badge     { padding: 2px 9px; border-radius: 10px; font-size: 12px; font-weight: bold; }
  .ir-badge-on  { background: #d4edda; color: #155724; }
  .ir-badge-off { background: #e2e3e5; color: #555; }

  /* Cron */
  .ir-cron-box { background: #fff9e6; border: 1px solid #f0d060; border-radius: 4px;
                 padding: 12px 14px; margin-top: 14px; clear: both; }
  .ir-cron-box .ir-cron-title { font-weight: bold; font-size: 13px; color: #7a5a00; margin-bottom: 5px; }
  .ir-cron-box .ir-cron-text  { font-size: 12px; color: #555; margin: 3px 0; }
  .ir-cron-code {
    display: block; background: #1e1e2e; color: #cdd6f4;
    font-family: monospace; font-size: 11px;
    padding: 8px 12px; border-radius: 4px; margin: 6px 0;
    white-space: pre; overflow-x: auto;
  }
</style>

<%# ── Toggle ── %>
<div class="ir-label"><%= l(:ir_auto_enabled_label) %></div>
<div class="ir-toggle-row">
  <span class="ir-tgl-wrap" onclick="var cb=this.querySelector('input');cb.checked=!cb.checked;cb.dispatchEvent(new Event('change'));">
    <input type="checkbox" id="ir-toggle"
           name="settings[auto_enabled]" value="1"
           <%= @settings['auto_enabled'] == '1' ? 'checked' : '' %>>
    <span class="ir-tgl-slider"></span>
  </span>
  <span id="ir-badge" class="ir-badge <%= @settings['auto_enabled'] == '1' ? 'ir-badge-on' : 'ir-badge-off' %>">
    <%= @settings['auto_enabled'] == '1' ? l(:ir_auto_status_enabled) : l(:ir_auto_status_disabled) %>
  </span>
</div>

<%# ── Días ── %>
<div class="ir-label"><%= l(:ir_auto_days_label) %></div>
<input type="number" id="ir-days" name="settings[auto_days]"
       value="<%= @settings['auto_days'] || '1' %>" min="1">

<%# ── Proyectos ── %>
<div class="ir-label">
  <%= l(:ir_auto_projects_label) %>
  <small>(Ctrl+clic = varios &mdash; vacío = todos)</small>
</div>
<%= select_tag 'settings[auto_project_ids][]',
      options_from_collection_for_select(
        Project.active.sorted, :id, :name,
        Array(@settings['auto_project_ids']).map(&:to_i)
      ),
      multiple: true, size: 6 %>

<%# ── Estados ── %>
<div class="ir-label">
  <%= l(:ir_auto_statuses_label) %>
  <small>(Ctrl+clic = varios &mdash; vacío = todos abiertos)</small>
</div>
<%= select_tag 'settings[auto_status_ids][]',
      options_from_collection_for_select(
        IssueStatus.where(is_closed: false).sorted, :id, :name,
        Array(@settings['auto_status_ids']).map(&:to_i)
      ),
      multiple: true, size: 6 %>

<%# ── Cron ── %>
<div class="ir-cron-box">
  <div class="ir-cron-title">⚙️ <%= l(:ir_auto_cron_title) %></div>
  <div class="ir-cron-text"><%= l(:ir_auto_cron_intro) %></div>
  <code class="ir-cron-code">0 8 * * * cd /opt/redmine && bundle exec rake redmine:issue_reminder:send RAILS_ENV=production >> /opt/redmine/log/issue_reminder.log 2>&1</code>
  <div class="ir-cron-text" style="color:#999;">Editá la hora (08:00) según tu preferencia.</div>
</div>

</div><%# /ir-plugin-settings %>

<script>
(function(){
  var t = document.getElementById('ir-toggle');
  var b = document.getElementById('ir-badge');
  var on  = <%= l(:ir_auto_status_enabled).to_json %>;
  var off = <%= l(:ir_auto_status_disabled).to_json %>;
  if(t) t.addEventListener('change', function(){
    b.textContent = t.checked ? on : off;
    b.className = 'ir-badge ' + (t.checked ? 'ir-badge-on' : 'ir-badge-off');
  });
})();
</script>
