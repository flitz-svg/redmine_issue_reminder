<style>
  .ir-cfg-table { width: 100%; border-collapse: collapse; }
  .ir-cfg-table tr td:first-child {
    width: 38%; font-weight: bold; font-size: 13px; color: #444;
    padding: 8px 12px 8px 0; vertical-align: top; padding-top: 10px;
  }
  .ir-cfg-table tr td:last-child { padding: 6px 0; }
  .ir-cfg-table tr + tr td { border-top: 1px solid #f0f0f0; }

  /* Toggle */
  .ir-toggle-wrap { position:relative; display:inline-block; width:44px; height:24px; vertical-align:middle; }
  .ir-toggle-wrap input { opacity:0; width:0; height:0; }
  .ir-slider { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background:#ccc; border-radius:24px; transition:.3s; }
  .ir-slider:before { position:absolute; content:""; height:18px; width:18px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.3s; }
  input:checked + .ir-slider { background:#628db6; }
  input:checked + .ir-slider:before { transform:translateX(20px); }
  .ir-badge { display:inline-block; margin-left:10px; padding:2px 10px; border-radius:10px; font-size:12px; font-weight:bold; vertical-align:middle; }
  .ir-badge-on  { background:#d4edda; color:#155724; }
  .ir-badge-off { background:#e2e3e5; color:#555; }

  /* Cron box */
  .ir-cron-box { background:#fff9e6; border:1px solid #f0d060; border-radius:4px; padding:12px 14px; margin-top:16px; }
  .ir-cron-box h4 { margin:0 0 6px; font-size:13px; color:#7a5a00; }
  .ir-cron-box p  { font-size:12px; color:#555; margin:0 0 6px; }
  .ir-cron-code { display:block; background:#1e1e2e; color:#cdd6f4; font-family:monospace; font-size:11px; padding:8px 12px; border-radius:4px; margin:6px 0; white-space:pre; overflow-x:auto; }
</style>

<table class="ir-cfg-table">
  <tr>
    <td><label for="ir-toggle"><%= l(:ir_auto_enabled_label) %></label></td>
    <td>
      <label class="ir-toggle-wrap">
        <input type="checkbox" id="ir-toggle"
               name="settings[auto_enabled]" value="1"
               <%= @settings['auto_enabled'] == '1' ? 'checked' : '' %>>
        <span class="ir-slider"></span>
      </label>
      <span id="ir-badge" class="ir-badge <%= @settings['auto_enabled'] == '1' ? 'ir-badge-on' : 'ir-badge-off' %>">
        <%= @settings['auto_enabled'] == '1' ? l(:ir_auto_status_enabled) : l(:ir_auto_status_disabled) %>
      </span>
    </td>
  </tr>

  <tr>
    <td><label for="ir-days"><%= l(:ir_auto_days_label) %></label></td>
    <td>
      <input type="number" id="ir-days" name="settings[auto_days]"
             value="<%= @settings['auto_days'] || '1' %>"
             min="1" style="width:60px;">
    </td>
  </tr>

  <tr>
    <td style="padding-top:8px;">
      <label><%= l(:ir_auto_projects_label) %></label>
      <br><small style="font-weight:normal; color:#888;">(Ctrl+clic = varios, vacío = todos)</small>
    </td>
    <td>
      <%= select_tag 'settings[auto_project_ids][]',
            options_from_collection_for_select(
              Project.active.sorted, :id, :name,
              Array(@settings['auto_project_ids']).map(&:to_i)
            ),
            multiple: true, size: 6, style: 'min-width:200px;' %>
    </td>
  </tr>

  <tr>
    <td style="padding-top:8px;">
      <label><%= l(:ir_auto_statuses_label) %></label>
      <br><small style="font-weight:normal; color:#888;">(Ctrl+clic = varios, vacío = todos)</small>
    </td>
    <td>
      <%= select_tag 'settings[auto_status_ids][]',
            options_from_collection_for_select(
              IssueStatus.where(is_closed: false).sorted, :id, :name,
              Array(@settings['auto_status_ids']).map(&:to_i)
            ),
            multiple: true, size: 6, style: 'min-width:200px;' %>
    </td>
  </tr>
</table>

<div class="ir-cron-box">
  <h4>⚙️ <%= l(:ir_auto_cron_title) %></h4>
  <p><%= l(:ir_auto_cron_intro) %></p>
  <code class="ir-cron-code">0 8 * * * cd /opt/redmine && bundle exec rake redmine:issue_reminder:send RAILS_ENV=production >> /opt/redmine/log/issue_reminder.log 2>&1</code>
  <p style="margin:0; font-size:12px; color:#888;">Editá la hora (08:00) según tu preferencia.</p>
</div>

<script>
(function(){
  var t = document.getElementById('ir-toggle');
  var b = document.getElementById('ir-badge');
  var on  = <%= l(:ir_auto_status_enabled).to_json %>;
  var off = <%= l(:ir_auto_status_disabled).to_json %>;
  t.addEventListener('change', function(){
    b.textContent = t.checked ? on : off;
    b.className = 'ir-badge ' + (t.checked ? 'ir-badge-on' : 'ir-badge-off');
  });
})();
</script>
